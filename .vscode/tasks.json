{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pip install requirements",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pip",
      "args": ["install", "-r", "requirements.txt"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Backend Server",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/uvicorn",
      "args": [
        "backend.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Frontend (npm start)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Format Code (Black)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/black",
      "args": [".", "--exclude", ".venv"]
    },
    {
      "label": "Lint Code (Pylint)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pylint",
      "args": ["backend/", "--disable=all", "--enable=E,F"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Install Frontend Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
